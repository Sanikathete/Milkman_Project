# Admin app (Vite)
#
# Recommended: use the same variable name as the customer frontend.
# For local dev, keep `/api` and rely on `vite.config.js` proxy.
# For production builds, set this to your deployed backend API base URL, including `/api`.
VITE_API_BASE_URL=/api
#
# Backward-compatible alias (optional)
# VITE_API_URL=/api

